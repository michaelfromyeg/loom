{
  "name": "@michaelfromyeg/weft-schema",
  "version": "1.1.0",
  "description": "Weft canonical data model: Zod schemas, types, and JSON-Schema export.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "emit-schemas": "bun scripts/emit-jsonschema.ts"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "yaml": "^2.6.1",
    "zod": "^4.0.5"
  },
  "license": "MIT",
  "author": "Michael DeMarco",
  "homepage": "https://github.com/michaelfromyeg/weft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelfromyeg/weft.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/michaelfromyeg/weft/issues"
  },
  "keywords": [
    "weft",
    "coding-agent",
    "ai-agent",
    "claude-code",
    "codex",
    "cursor",
    "copilot",
    "opencode",
    "mcp",
    "plugin",
    "skill",
    "compiler"
  ],
  "publishConfig": {
    "access": "public"
  }
}
