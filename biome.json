{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": ["**", "!**/dist", "!**/*.json5", "!packages/schema/schemas"]
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noImportCycles": "error",
        "noConsole": "error",
        "useAwait": "error",
        "noEmptyBlockStatements": "error",
        "noConstEnum": "error"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "noParameterAssign": "error",
        "useNodejsImportProtocol": "error",
        "useThrowOnlyError": "error",
        "useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
        "useCollapsedElseIf": "error",
        "noNonNullAssertion": "error",
        "useShorthandAssign": "error",
        "noYodaExpression": "error",
        "useForOf": "error",
        "noNegationElse": "error"
      },
      "complexity": {
        "useSimplifiedLogicExpression": "error",
        "noUselessStringConcat": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error"
      },
      "performance": {
        "noReExportAll": "error"
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always" }
  },
  "overrides": [
    {
      "includes": ["packages/schema/scripts/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": ["**/test/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off", "useAwait": "off" } } }
    }
  ]
}
