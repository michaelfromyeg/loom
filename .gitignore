node_modules/
dist/
*.tsbuildinfo
coverage/
.DS_Store
*.log

# Weft build output / local install artifacts in test sandboxes
.weft-out/
.weft-sandbox/

# never commit resolved secrets
.env
.env.*
!.env.example

# generated JSON schemas (regenerated on build)
packages/schema/schemas/

# fixture install artifacts (never commit; machine-specific paths)
fixtures/**/weft.lock
fixtures/**/.weft/
fixtures/**/weft.sig
fixtures/**/weft.pub

# marketplace install artifacts (written when installing the repo's own marketplace)
marketplace/**/weft.lock
marketplace/**/.weft/
