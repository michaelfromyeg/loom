{
  "name": "loom-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "loom": "bun packages/cli/src/index.ts",
    "changeset": "changeset",
    "release": "changeset publish",
    "test:coverage": "vitest run --coverage",
    "docs:cli": "bun packages/cli/src/index.ts docs --out docs/cli.md"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
